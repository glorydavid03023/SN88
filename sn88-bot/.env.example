# =============================
# SN88 Tao/Alpha strategy bot
# =============================

# Put your Taostats API key here. Keep this file private.
TAOSTATS_API_KEY=tao-f9666783-2f32-4968-bf21-c40bcd53c030:375b3b1c

# Path to your cloned mobiusfund/investing repo.
# Example: /root/investing or /home/ubuntu/investing
INVESTING_DIR=/root/investing

# Your miner hotkey SS58. Strategy file will be:
# $INVESTING_DIR/Investing/strat/$HOTKEY_SS58
HOTKEY_SS58=5Gs7EEtVY7W1xGCRBUAVEc36A83W8Jpf3EEkg1txVMrw26q7

# Data source: taostats or csv
SUBNET_DATA_SOURCE=taostats

# Taostats base URL and subnets endpoint.
# If this endpoint fails, the bot also tries a few common fallback endpoints.
TAOSTATS_BASE_URL=https://api.taostats.io
TAOSTATS_SUBNETS_ENDPOINT=/api/dtao/subnet/latest/v1

# CSV fallback/testing input
CSV_PATH=./data/subnets_sample.csv

# Optional: save fetched Taostats payloads locally (for debugging/audit).
# Writes into FETCHED_DATA_DIR inside this project.
SAVE_FETCHED_DATA=false
FETCHED_DATA_DIR=./data/taostats

# Strategy rules
TOP_N=10
MIN_LIQUIDITY_TAO=5000
MAX_WEIGHT=0.20
MIN_WEIGHT=0.03
MAX_1H_PUMP=35
EXCLUDE_NETUIDS=0

# Scoring weights
W_7D=0.45
W_1D=0.25
W_1H=0.10
W_LIQUIDITY=0.10
W_FLOW=0.10
W_EMISSION=0.10
W_DRAWDOWN=0.25

# Safety
DRY_RUN=false
BACKUP_OLD_STRATEGY=true
